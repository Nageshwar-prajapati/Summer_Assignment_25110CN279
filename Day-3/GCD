#include<stdio.h>
int main()
{
    int num1,num2,flag=0;
    printf("Enter the first number: ");
    scanf("%d",&num1);

    printf("Enter the second number: ");
    scanf("%d",&num2);

    for(int i=1; i<=num1 && i<=num2; i++){
        if(num1%i==0 && num2%i==0){
            flag=i;
        }
    }

    printf("GCD of numbers: %d",flag);

    return 0;
}

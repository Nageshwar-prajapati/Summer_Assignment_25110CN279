#include<stdio.h>
int main()
{
    int num1,num2,flag=1;
    printf("Enter the first number: ");
    scanf("%d",&num1);

    printf("Enter the second number: ");
    scanf("%d",&num2);


    for(int i=2; i<=num1 && i<=num2; i++){
        if(num1%i==0 && num2%i==0){
            flag=i;
            break;
        }
    }

    printf("LCM of numbers: %d",flag);

    return 0;
}

#include<stdio.h>
int main()
{
    int num,ran;

    printf("Enter the range: ");
    scanf("%d",&ran);

    printf("Prime number between 1 and %d :",ran);
    for(int i=1; i<=ran; i++){
        int flag=0;
        for(int j=2; j<=i/2; j++){
            if(i%j==0){
                flag=1;
                break;
            }
        }
        if(flag==0){
            printf("%d ",i);
        }
    }
        
    return 0;
}

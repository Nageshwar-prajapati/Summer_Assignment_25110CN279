#include<stdio.h>
int main()
{
    int num, rev=0, rem, num1;
    printf("Enter the number: ");
    scanf("%d",&num);
    num1=num;

    while(num!=0){
        rem=num%10;
        num=num/10;
        rev=rev*10+rem;
    }

    if(num1==rev)
        printf("It's a palindrome");
    else
        printf("It is not a palindrome");


    return 0;
}
